{
  "manifest_version": 3,
  "name": "VoidVault",
  "version": "1.2.2",
  "description": "Gestor de contraseñas zero-knowledge — cifrado en tu dispositivo",
  "action": {
    "default_title": "VoidVault",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "activeTab",
    "windows",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://api.pwnedpasswords.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "badge.css"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}