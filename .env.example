# Copia a .env y rellena. No subir .env al repositorio.

# Obligatorio. Generar con: openssl rand -hex 32
SECRET_KEY=

# Opcional (por defecto 15)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Base de datos
# Local: sqlite (por defecto sqlite:///./vault.db)
# Docker: sqlite:////data/vault.db (volumen en /data)
# Producción: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./vault.db

# CORS (solo en producción). Orígenes permitidos separados por coma.
# Ej: https://tudominio.com,chrome-extension://abcdefghijklmnop
# Dejar vacío o no definir = permitir todo (*) para desarrollo.
CORS_ORIGINS=
